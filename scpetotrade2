-- EKSTRAKSI KUNCI ASLI DARI SERVER UNTUK GEAR
local function resolveItem(tool)
    local name = tool.Name
    
    local uuid = tool:GetAttribute("PetId") 
        or tool:GetAttribute("Id") 
        or tool:GetAttribute("UUID")
        or tool:GetAttribute("AssetId")
        or tool:GetAttribute("ItemID")
        or tool:GetAttribute("TemplateID")
    
    local category = "Seeds"
    if GEAR_NAMES[name] then
        category = "Gear"
    else
        local attrCat = tool:GetAttribute("Category") or tool:GetAttribute("ItemType") or tool:GetAttribute("Type")
        if attrCat then
            category = tostring(attrCat)
            if category == "Gears" then category = "Gear" end
        end
    end
    
    local finalKey = (category == "Gear" and uuid) and tostring(uuid) or name
    return category, finalKey
end

local Net = nil
local function getNet()
    if Net then return Net end
    pcall(function()
        local sm = RS:WaitForChild("SharedModules", 10)
        local nw = sm:WaitForChild("Networking", 10)
        Net = require(nw)
    end)
    return Net
end

local function getUserId(username)
    local ok, uid = pcall(Players.GetUserIdFromNameAsync, Players, username)
    return ok and uid or nil
end

local function getInventoryItems()
    local items = {}
    local function scanContainer(container)
        for _, tool in pairs(container:GetChildren()) do
            if tool:IsA("Tool") then
                local internalCount = tool:GetAttribute("Count")
                    or tool:GetAttribute("Stack")
                    or tool:GetAttribute("Amount")
                    or tool:GetAttribute("Quantity")
                    or tool:GetAttribute("Uses")
                    or 1
                internalCount = math.max(tonumber(internalCount) or 1, 1)
                
                table.insert(items, {
                    name  = tool.Name,
                    count = internalCount,
                    tool  = tool
                })
            end
        end
    end
    scanContainer(LP.Backpack)
    if LP.Character then scanContainer(LP.Character) end
    return items
end

local function sendInChunks(userId, batch)
    local net = getNet()
    if not net or not net.Mailbox then return false, "Net.Mailbox tidak tersedia" end
    local ok, err = pcall(function()
        net.Mailbox.SendBatch:Fire(userId, batch, "")
    end)
    return ok, err
end

