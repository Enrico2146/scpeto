Instance.new("UICorner", sendBtn).CornerRadius = UDim.new(0, 8)

local isSending = false

sendBtn.MouseButton1Click:Connect(function()
    if isSending then return end

    local recipient = recipientBox.Text:match("^%s*(.-)%s*$")
    if recipient == "" then
        setStatus("Masukkan username penerima!", false)
        return
    end

    if not selectedItem then
        setStatus("Pilih item dulu!", false)
        return
    end

    local amount = math.floor(tonumber(amountBox.Text) or 0)
    if amount <= 0 then
        setStatus("Amount harus lebih dari 0!", false)
        return
    end
    if amount > selectedItem.count then
        setStatus("Amount melebihi stok (" .. selectedItem.count .. ")!", false)
        return
    end

    isSending = true
    sendBtn.Text             = "Sending..."
    sendBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
    setStatus("", true)

    task.spawn(function()
        local userId = getUserId(recipient)
        if not userId then
            setStatus("Username tidak ditemukan!", false)
            sendBtn.Text             = "Send Trade"
            sendBtn.BackgroundColor3 = Color3.fromRGB(0, 160, 100)
            isSending = false
            return
        end

        local itemKey   = selectedItem.name
        local category  = "Seeds"
        local toolRef   = selectedItem.tool

        if toolRef and toolRef.Parent then
            category, itemKey = resolveItem(toolRef)
        end

        -- ==========================================================
        -- ROMBAKAN UTAMA: STRUKTUR PAYLOAD KHUSUS GEARS
        -- ==========================================================
        local payload = {}
        
        if category == "Gears" then
            -- Server membutuhkan referensi data unik objek asli, bukan teks stack
            for i = 1, amount do
                table.insert(payload, {
                    ItemKey  = toolRef,        -- Mengirim objek Tool langsung jika text ditolak
                    Category = "Gears",
                    Count    = 1,              -- Gears dikirim per-biji (bukan ditumpuk)
                    ItemName = itemKey
                })
            end
        else
            -- Format Normal untuk Seeds dan Pets
            payload = {{
                ItemKey  = itemKey,
                Count    = amount,
                Category = category,
            }}
        end
        -- ==========================================================

        local sendOk, sendErr = sendInChunks(userId, payload)

        if sendOk then
            setStatus("Berhasil dikirim ke " .. recipient .. "!", true)
            selectedItem       = nil
            dropBtn.Text       = "Pilih item..."
            dropBtn.TextColor3 = Color3.fromRGB(90, 90, 110)
            amountBox.Text     = "1"
        else
            setStatus("Gagal: " .. tostring(sendErr), false)
        end

        sendBtn.Text             = "Send Trade"
        sendBtn.BackgroundColor3 = Color3.fromRGB(0, 160, 100)
        isSending = false
    end)
end)
