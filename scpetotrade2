local isSending = false
sendBtn.MouseButton1Click:Connect(function()
    if isSending then return end

    local recipient = recipientBox.Text:match("^%s*(.-)%s*$")
    if recipient == "" then setStatus("Masukkan username penerima!", false) return end
    if not selectedItem then setStatus("Pilih item dulu!", false) return end

    local amount = math.floor(tonumber(amountBox.Text) or 0)
    if amount <= 0 then setStatus("Amount harus lebih dari 0!", false) return end
    if amount > selectedItem.count then setStatus("Amount melebihi stok!", false) return end

    isSending = true
    sendBtn.Text = "Sending..."
    sendBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 100)

    task.spawn(function()
        local userId = getUserId(recipient)
        if not userId then
            setStatus("Username tidak ditemukan!", false)
            sendBtn.Text = "Send Trade"; isSending = false return
        end

        local category, itemKey = resolveItem(selectedItem.tool)

        local payload = {}
        if category == "Gear" then
            -- Penyelarasan MUTLAK sesuai log console game: menggunakan kategori tunggal "Gear"
            table.insert(payload, {
                ItemKey  = itemKey,
                Category = "Gear",
                Count    = amount
            })
            print("[TradeMail] DEBUG Category: Gear | ItemKey: " .. tostring(itemKey))
        else
            payload = {{
                ItemKey  = itemKey,
                Count    = amount,
                Category = category,
            }}
            print("[TradeMail] DEBUG Category: " .. tostring(category) .. " | ItemKey: " .. tostring(itemKey))
        end

        print("[TradeMail] Kirim: " .. tostring(selectedItem.name) .. " [" .. tostring(category) .. "] x" .. tostring(amount) .. " -> " .. recipient .. " (uid " .. tostring(userId) .. ")")

        local sendOk, sendErr = sendInChunks(userId, payload)
        if sendOk then
            setStatus("Berhasil dikirim ke " .. recipient .. "!", true)
            print("[TradeMail] Chunk terkirim 1/1 item")
            selectedItem = nil
            dropBtn.Text = "Pilih item..."
            amountBox.Text = "1"
        else
            setStatus("Gagal: " .. tostring(sendErr), false)
        end

        sendBtn.Text = "Send Trade"
        sendBtn.BackgroundColor3 = Color3.fromRGB(0, 160, 100)
        isSending = false
    end)
end)
