local function closeDropdown()
    dropOpen = false
    dropList.Size = UDim2.new(1, -20, 0, 0)
end

local function populateDropdown()
    for _, c in pairs(dropScroll:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end
    end

    local items = getInventoryItems()
    if #items == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size               = UDim2.new(1, 0, 0, 34)
        empty.BackgroundTransparency = 1
        empty.Text               = "Inventory kosong"
        empty.TextColor3         = Color3.fromRGB(120, 120, 140)
        empty.TextSize           = 12
        empty.Font               = Enum.Font.Gotham
        empty.ZIndex             = 20
        empty.LayoutOrder        = 1
        empty.Parent             = dropScroll
        dropScroll.CanvasSize    = UDim2.new(0, 0, 0, 34)
        return 0
    end

    for idx, item in ipairs(items) do
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1, 0, 0, 34)
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
        btn.BackgroundTransparency = 0.35
        btn.Text             = item.name .. "  (x" .. item.count .. ")"
        btn.TextColor3       = Color3.fromRGB(210, 210, 225)
        btn.TextSize         = 12
        btn.Font             = Enum.Font.Gotham
        btn.BorderSizePixel  = 0
        btn.ZIndex           = 20
        btn.LayoutOrder      = idx
        btn.Parent           = dropScroll

        local pad = Instance.new("UIPadding")
        pad.PaddingLeft = UDim.new(0, 10)
        pad.Parent      = btn

        btn.MouseButton1Click:Connect(function()
            selectedItem       = item
            dropBtn.Text       = item.name .. "  (x" .. item.count .. ")"
            dropBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
            closeDropdown()
        end)
    end

    dropScroll.CanvasSize = UDim2.new(0, 0, 0, #items * 34)
    return #items
end

dropBtn.MouseButton1Click:Connect(function()
    if dropOpen then
        closeDropdown()
    else
        local count = populateDropdown()
        dropOpen = true
        local visibleRows = math.min(count == 0 and 1 or count, 4)
        dropList.Size = UDim2.new(1, -20, 0, visibleRows * 34)
    end
end)

