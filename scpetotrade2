local function closeDropdown()
    dropOpen = false
    dropList.Size = UDim2.new(1, -20, 0, 0)
end

local function populateDropdown()
    for _, c in pairs(dropScroll:GetChildren()) do
        if c:IsA("TextButton") or c:IsA("TextLabel") then c:Destroy() end
    end

    local rawItems = getInventoryItems()
    local merged = {}
    local uniqueList = {}

    for _, it in pairs(rawItems) do
        if not merged[it.name] then
            merged[it.name] = { total = 0, ref = it.tool }
            table.insert(uniqueList, it.name)
        end
        merged[it.name].total = merged[it.name].total + it.count
    end

    if #uniqueList == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 34)
        empty.BackgroundTransparency = 1
        empty.Text = "Taruh item di Hotbar bawah dulu!"
        empty.TextColor3 = Color3.fromRGB(220, 100, 100)
        empty.TextSize = 12
        empty.Font = Enum.Font.Gotham
        empty.ZIndex = 20
        empty.Parent = dropScroll
        dropScroll.CanvasSize = UDim2.new(0, 0, 0, 34)
        return 0
    end

    for idx, name in ipairs(uniqueList) do
        local data = merged[name]
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 34)
        btn.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
        btn.Text = name .. "  (x" .. data.total .. ")"
        btn.TextColor3 = Color3.fromRGB(210, 210, 225)
        btn.TextSize = 12
        btn.Font = Enum.Font.Gotham
        btn.BorderSizePixel = 0
        btn.ZIndex = 20
        btn.LayoutOrder = idx
        btn.Parent = dropScroll
        
        local pad = Instance.new("UIPadding")
        pad.PaddingLeft = UDim.new(0, 10)
        pad.Parent = btn

        btn.MouseButton1Click:Connect(function()
            selectedItem = { name = name, count = data.total, tool = data.ref }
            dropBtn.Text       = name .. "  (x" .. data.total .. ")"
            dropBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
            closeDropdown()
        end)
    end

    dropScroll.CanvasSize = UDim2.new(0, 0, 0, #uniqueList * 34)
    return #uniqueList
end

dropBtn.MouseButton1Click:Connect(function()
    if dropOpen then closeDropdown() else
        local count = populateDropdown()
        dropOpen = true
        dropList.Size = UDim2.new(1, -20, 0, math.min(count == 0 and 1 or count, 4) * 34)
    end
end)

