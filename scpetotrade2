local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

-- ================= NET =================
local Net = nil
local function getNet()
    if Net then return Net end
    pcall(function()
        local sm = RS:WaitForChild("SharedModules", 10)
        local nw = sm:WaitForChild("Networking", 10)
        Net = require(nw)
    end)
    return Net
end

-- ================= DATA =================
local selectedItem = nil
local isSending = false

local GEAR_NAMES = {
    ["Common Watering Can"] = true,
    ["Common Sprinkler"] = true,
    ["Uncommon Sprinkler"] = true,
    ["Rare Sprinkler"] = true,
    ["Legendary Sprinkler"] = true,
}

-- ================= UI =================
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "TradeMail_FIX"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 300, 0, 200)
frame.Position = UDim2.new(0.5, -150, 0.5, -100)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)

local nameBox = Instance.new("TextBox", frame)
nameBox.Size = UDim2.new(1, -20, 0, 30)
nameBox.Position = UDim2.new(0, 10, 0, 10)
nameBox.PlaceholderText = "Username"

local amountBox = Instance.new("TextBox", frame)
amountBox.Size = UDim2.new(1, -20, 0, 30)
amountBox.Position = UDim2.new(0, 10, 0, 50)
amountBox.PlaceholderText = "Amount"

local sendBtn = Instance.new("TextButton", frame)
sendBtn.Size = UDim2.new(1, -20, 0, 40)
sendBtn.Position = UDim2.new(0, 10, 0, 100)
sendBtn.Text = "SEND"

local status = Instance.new("TextLabel", frame)
status.Size = UDim2.new(1, -20, 0, 30)
status.Position = UDim2.new(0, 10, 0, 150)
status.Text = ""

-- ================= LOGIC =================
local function getUserId(name)
    local ok, uid = pcall(function()
        return Players:GetUserIdFromNameAsync(name)
    end)
    return ok and uid or nil
end

local function getItems()
    local items = {}
    for _,t in pairs(LP.Backpack:GetChildren()) do
        if t:IsA("Tool") then
            table.insert(items, t)
        end
    end
    return items
end

local function resolve(tool)
    local name = tool.Name
    local uuid = tool:GetAttribute("UUID") or tool:GetAttribute("Id")

    local category = GEAR_NAMES[name] and "Gear" or "Seeds"
    local key = (category == "Gear" and uuid) and tostring(uuid) or name

    return category, key
end

local function send(userId, payload)
    local net = getNet()
    if not net or not net.Mailbox then return false end

    local ok = pcall(function()
        net.Mailbox.SendBatch:Fire(userId, payload, "")
    end)

    return ok
end

-- ================= CLICK =================
sendBtn.MouseButton1Click:Connect(function()
    if isSending then return end
    isSending = true

    local username = nameBox.Text
    local amount = tonumber(amountBox.Text) or 1

    local userId = getUserId(username)
    if not userId then
        status.Text = "User tidak ditemukan"
        isSending = false
        return
    end

    local items = getItems()
    local tool = items[1]

    if not tool then
        status.Text = "No item"
        isSending = false
        return
    end

    local category, key = resolve(tool)

    local payload = {{
        ItemKey = key,
        Category = category,
        Count = amount
    }}

    local ok = send(userId, payload)

    if ok then
        status.Text = "Request sent"
    else
        status.Text = "Failed send"
    end

    isSending = false
end)
