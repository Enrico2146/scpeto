local function getUserId(username)
    local ok, uid = pcall(Players.GetUserIdFromNameAsync, Players, username)
    return ok and uid or nil
end

-- Ambil semua tool dari backpack
local function getInventoryItems()
    local items = {}
    for _, tool in pairs(LP.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            local count = tool:GetAttribute("Count")
                or tool:GetAttribute("Stack")
                or tool:GetAttribute("Amount")
                or tool:GetAttribute("Quantity")
                or 1
            count = math.max(tonumber(count) or 1, 1)
            table.insert(items, {
                name  = tool.Name,
                count = count,
                tool  = tool,  
            })
        end
    end
    return items
end

-- Kirim item dalam chunks ke server
local function sendInChunks(userId, batch)
    local net = getNet()
    if not net or not net.Mailbox then
        return false, "Net.Mailbox tidak tersedia"
    end

    local total = #batch
    local sent  = 0

    for i = 1, total, MAX_PER_BATCH do
        local chunk = {}
        for j = i, math.min(i + MAX_PER_BATCH - 1, total) do
            table.insert(chunk, batch[j])
        end

        local ok, err = pcall(function()
            net.Mailbox.SendBatch:Fire(userId, chunk, "")
        end)

        if ok then
            sent = sent + #chunk
            print(("[TradeMail] Chunk terkirim %d/%d item"):format(sent, total))
        else
            warn("[TradeMail] Gagal chunk: " .. tostring(err))
            return false, err
        end

        if i + MAX_PER_BATCH <= total then
            task.wait(1)
        end
    end

    return true, nil
end

