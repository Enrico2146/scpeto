-- Tentukan kategori dari tool.
local function resolveItem(tool)
    local name = tool.Name

    -- 1. Pet? Punya attribute UUID
    local uuid = tool:GetAttribute("PetId")
        or tool:GetAttribute("Id")
        or tool:GetAttribute("UUID")
    if uuid then
        return "Pets", uuid
    end

    -- 2. Gear? Cocokkan dengan daftar GEAR_NAMES (Pakai kategori "Gears" dengan 's')
    if GEAR_NAMES[name] then
        return "Gears", name
    end

    -- 3. Kategori eksplisit dari attribute game
    local attrCat = tool:GetAttribute("Category") or tool:GetAttribute("ItemType") or tool:GetAttribute("Type")
    if attrCat then
        if tostring(attrCat) == "Gear" then attrCat = "Gears" end
        return tostring(attrCat), name
    end

    -- 4. Default: Seeds
    return "Seeds", name
end

-- ============================================
-- LOAD NETWORKING MODULE
-- ============================================

local Net = nil

local function getNet()
    if Net then return Net end
    local ok, result = pcall(function()
        local sm = RS:WaitForChild("SharedModules", 10)
        if not sm then return nil end
        local nw = sm:WaitForChild("Networking", 10)
        if not nw then return nil end
        return require(nw)
    end)
    if ok and result then
        Net = result
    else
        warn("[TradeMail] Gagal load Networking: " .. tostring(result))
    end
    return Net
end

