local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local Net = nil

local function getNet()
    if Net then return Net end
    pcall(function()
        local sm = RS:WaitForChild("SharedModules", 10)
        local nw = sm:WaitForChild("Networking", 10)
        Net = require(nw)
    end)
    return Net
end

local GEAR_NAMES = {
    ["Common Watering Can"] = true,
    ["Common Sprinkler"] = true,
    ["Uncommon Sprinkler"] = true,
    ["Rare Sprinkler"] = true,
    ["Legendary Sprinkler"] = true,
    ["Super Sprinkler"] = true,
}

local function getUserId(username)
    local ok, uid = pcall(function()
        return Players:GetUserIdFromNameAsync(username)
    end)
    return ok and uid or nil
end

local function getInventory()
    local items = {}

    local function scan(container)
        for _, t in pairs(container:GetChildren()) do
            if t:IsA("Tool") then
                table.insert(items, t)
            end
        end
    end

    scan(LP.Backpack)
    if LP.Character then scan(LP.Character) end

    return items
end

local function resolveItem(tool)
    local name = tool.Name

    local uuid =
        tool:GetAttribute("UUID")
        or tool:GetAttribute("Id")
        or tool:GetAttribute("ItemID")

    local category = "Seeds"

    if GEAR_NAMES[name] then
        category = "Gear"
    end

    local key = (category == "Gear" and uuid) and tostring(uuid) or name

    return category, key
end

local function send(userId, payload)
    local net = getNet()
    if not net or not net.Mailbox then
        return false, "Mailbox not found"
    end

    local ok, err = pcall(function()
        net.Mailbox.SendBatch:Fire(userId, payload, "")
    end)

    return ok, err
end

-- ================= GUI STATE =================
local isSending = false
local selectedItem = nil

-- ================= MAIN SEND =================
local function sendTrade(recipient, amount)
    if isSending then return end
    isSending = true

    local userId = getUserId(recipient)
    if not userId then
        print("[ERROR] User not found")
        isSending = false
        return
    end

    if not selectedItem then
        print("[ERROR] No item selected")
        isSending = false
        return
    end

    local category, key = resolveItem(selectedItem.tool)

    local payload = {{
        ItemKey = tostring(key),
        Category = category,
        Count = tonumber(amount)
    }}

    print("[TRADE] Sending:", selectedItem.tool.Name, category, key)

    local ok, err = send(userId, payload)

    task.wait(1.5)

    if ok then
        print("[TRADE] Request sent (NOT CONFIRMED SERVER SUCCESS)")
    else
        print("[TRADE] Failed:", err)
    end

    isSending = false
end
